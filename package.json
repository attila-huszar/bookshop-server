{
  "name": "bookshop-server",
  "module": "app.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/app.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "bun src/database/migrate.ts",
    "seed": "bun src/database/seed.ts",
    "worker:email": "bun src/workers/email.worker.ts",
    "cron:cleanup": "bun src/scripts/cleanupTokens.ts",
    "backup:sqlite": "bun src/scripts/backupSqlite.ts",
    "backup:mongo": "bun src/scripts/backupMongo.ts"
  },
  "bun": {
    "test": {
      "preload": [
        "src/tests/test-setup.ts"
      ]
    }
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "hono-rate-limiter": "^0.5.3",
    "http-status": "^2.1.0",
    "mjml": "^4.18.0",
    "mongoose": "^9.3.1",
    "nodemailer": "^8.0.3",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.11",
    "@types/mjml": "^4.7.4",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
