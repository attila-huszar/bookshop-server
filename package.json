{
  "name": "bookshop-server",
  "module": "app.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,worker -c green,cyan \"bun run dev:server\" \"bun run dev:worker\"",
    "dev:server": "bun --hot src/app.ts",
    "dev:worker": "bun --watch src/workers/email.worker.ts",
    "lint": "bun --bun eslint . --max-warnings 0",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "bun src/database/migrate.ts",
    "seed": "bun src/database/seed.ts",
    "worker:email": "bun src/workers/email.worker.ts",
    "cron:cleanup": "bun src/scripts/cleanupTokens.ts",
    "backup:sqlite": "bun src/scripts/backupSqlite.ts",
    "backup:mongo": "bun src/scripts/backupMongo.ts"
  },
  "bun": {
    "test": {
      "preload": [
        "src/tests/test-setup.ts"
      ]
    }
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "bullmq": "^5.75.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.14",
    "hono-rate-limiter": "^0.5.3",
    "http-status": "^2.1.0",
    "mjml": "^5.0.1",
    "mongoose": "^9.5.0",
    "nodemailer": "^8.0.5",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.12",
    "@types/mjml": "^5.0.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
